{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "statusMessage": "Formatting with Xcode Format…",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/xcode-format.sh"
          }
        ]
      }
    ]
  }
}
